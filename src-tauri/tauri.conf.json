{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RuneWise",
  "version": "1.0.0",
  "identifier": "com.mcnerve.runewise",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "RuneWise",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://secure.runescape.com https://prices.runescape.wiki https://oldschool.runescape.wiki https://api.wiseoldman.net https://public.starminers.site https://templeosrs.com https://maps.runescape.wiki; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://oldschool.runescape.wiki https://maps.runescape.wiki https://secure.runescape.com; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/McNerve/runewise/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2MTU1MjQyRDM2M0IxRgpSV1FmT3pZdEpGVmhCaCtaY0FlV01sUFZmdFRKV0xxdk9TTm4xYmE1Q2U2eklxNE1kc1hqTHIzTQo="
    }
  }
}